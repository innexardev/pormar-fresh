DATABASE_URL="postgresql://freshbox:freshbox@localhost:5433/freshbox?schema=public"
JWT_SECRET="change-me-freshbox-secret-key"
API_PORT=3010
NEXT_PUBLIC_API_URL="http://localhost:3010/api/v1"
NEXT_PUBLIC_STORE_NAME="Pomar Fresh"
NEXT_PUBLIC_SITE_URL="http://localhost:3020"

# MinIO (S3-compatible) — uploads de imagens
S3_ENDPOINT="http://localhost:9000"
S3_PUBLIC_URL="http://localhost:9000/pomar-fresh"
S3_BUCKET="pomar-fresh"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_REGION="us-east-1"

# Areas de entrega (fallback se nao houver zonas no admin)
# Exemplo Praia Grande: 11700,11701,11702,11703,11704,11705,11706,11707
DELIVERY_ZIP_PREFIXES=

# Pix Asaas
ASAAS_API_KEY=
ASAAS_SANDBOX=true
ASAAS_WEBHOOK_TOKEN=

# WhatsApp — Evolution API (ver docs/PLANO-MASTER-COMPLETO.md)
WHATSAPP_API_URL=http://localhost:8080
WHATSAPP_API_KEY=change-me-evolution-key
WHATSAPP_INSTANCE=pomar-fresh

# Segurança produção
ALLOW_PIX_SIMULATE=false

# Push notifications (PWA) — chave pública (privada fica em .env, não commitar)
VAPID_PUBLIC_KEY="BF2ksV2csTZjNyKpP-U-tgP4x0pFCIkJeEM-rWcbxUGe87YBNrcXJ-W7PHgPaNNkmz1E5G_o170VIUpJlTtId8M"
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:admin@pomarfresh.com"
