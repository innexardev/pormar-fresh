{
  "name": "fresh-box-online",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:admin\"",
    "dev:api": "npm run dev --workspace=@freshbox/api",
    "dev:web": "npm run dev --workspace=@freshbox/web",
    "dev:admin": "npm run dev --workspace=@freshbox/admin",
    "db:generate": "npm run prisma:generate --workspace=@freshbox/api",
    "db:migrate": "npm run prisma:migrate --workspace=@freshbox/api",
    "db:seed": "npm run prisma:seed --workspace=@freshbox/api",
    "docker:up": "docker compose up -d"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
